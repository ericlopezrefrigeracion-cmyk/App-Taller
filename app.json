{
  "expo": {
    "name": "ClimaDesk Técnicos",
    "slug": "app-taller-tecnicos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "climadesk-tecnicos",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ericlopez.climadesk.tecnicos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ericlopez.climadesk.tecnicos",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app necesita tu ubicación para verificar que estás en el taller al fichar.",
          "locationWhenInUsePermission": "La app necesita tu ubicación para verificar que estás en el taller al fichar."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a tus fotos para adjuntar evidencias de trabajo.",
          "cameraPermission": "La app necesita la cámara para fotografiar el trabajo realizado."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3f1da022-7693-430c-b562-ec632e3ea08f"
      }
    },
    "owner": "eric123456"
  }
}
